@page "/pracownicy"
@rendermode InteractiveServer

@using UrlopyJarex.Models
@using UrlopyJarex.Services

@inject EmployeeService EmployeeService

<PageTitle>Pracownicy</PageTitle>

<h1>Pracownicy</h1>

<p class="text-muted">
    Słownik pracowników używany przy wnioskach urlopowych, limitach i zastępstwach.
</p>

@if (!string.IsNullOrWhiteSpace(message))
{
    <div class="alert @(success ? "alert-success" : "alert-danger")">
        @message
    </div>
}

<div class="card mb-4">
    <div class="card-header">
        @(editingEmployeeId is null ? "Dodaj pracownika" : "Edytuj pracownika")
    </div>

    <div class="card-body">
        <EditForm Model="formModel" OnValidSubmit="SaveAsync">
            <DataAnnotationsValidator />

            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Imię</label>
                    <InputText class="form-control" @bind-Value="formModel.FirstName" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Nazwisko</label>
                    <InputText class="form-control" @bind-Value="formModel.LastName" />
                </div>

                <div class="col-md-4">
                    <label class="form-label">E-mail</label>
                    <InputText class="form-control" @bind-Value="formModel.Email" />
                </div>

                <div class="col-md-2 d-flex align-items-end">
                    <div class="form-check">
                        <InputCheckbox class="form-check-input" @bind-Value="formModel.IsActive" />
                        <label class="form-check-label">Aktywny</label>
                    </div>
                </div>

                <div class="col-md-12">
                    <div class="form-check">
                        <InputCheckbox class="form-check-input" @bind-Value="formModel.IsCoordinator" />
                        <label class="form-check-label">
                            Koordynator urlopów
                        </label>
                    </div>
                    <div class="form-text">
                        Na tym etapie aplikacja obsługuje jednego koordynatora. Zaznaczenie tej opcji zdejmie koordynatora z innych pracowników.
                    </div>
                </div>
            </div>

            <div class="mt-3">
                <button class="btn btn-primary" type="submit">
                    Zapisz
                </button>

                @if (editingEmployeeId is not null)
                {
                    <button class="btn btn-secondary ms-2" type="button" @onclick="CancelEdit">
                        Anuluj edycję
                    </button>
                }
            </div>
        </EditForm>
    </div>
</div>

@if (employees is null)
{
    <p>Ładowanie pracowników...</p>
}
else if (!employees.Any())
{
    <div class="alert alert-info">
        Brak pracowników. Dodaj pierwszego pracownika powyżej.
    </div>
}
else
{
    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>Pracownik</th>
                <th>E-mail</th>
                <th>Koordynator</th>
                <th>Status</th>
                <th style="width: 260px;">Akcje</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var employee in employees)
            {
                <tr>
                    <td>
                        <strong>@employee.FullName</strong>
                    </td>
                    <td>@employee.Email</td>
                    <td>
                        @if (employee.IsCoordinator)
                        {
                            <span class="badge bg-primary">Tak</span>
                        }
                        else
                        {
                            <span class="text-muted">Nie</span>
                        }
                    </td>
                    <td>
                        @if (employee.IsActive)
                        {
                            <span class="badge bg-success">Aktywny</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Nieaktywny</span>
                        }
                    </td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary" @onclick="() => Edit(employee)">
                            Edytuj
                        </button>

                        @if (!employee.IsCoordinator && employee.IsActive)
                        {
                            <button class="btn btn-sm btn-outline-dark ms-1" @onclick="() => SetCoordinatorAsync(employee.Id)">
                                Ustaw koordynatora
                            </button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Employee>? employees;

    private Employee formModel = new()
    {
        IsActive = true
    };

    private int? editingEmployeeId;

    private string? message;
    private bool success;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        employees = (await EmployeeService.GetAllAsync()).ToList();
    }

    private async Task SaveAsync()
    {
        ClearMessage();

        if (string.IsNullOrWhiteSpace(formModel.FirstName))
        {
            SetMessage(false, "Imię jest wymagane.");
            return;
        }

        if (string.IsNullOrWhiteSpace(formModel.LastName))
        {
            SetMessage(false, "Nazwisko jest wymagane.");
            return;
        }

        formModel.FirstName = formModel.FirstName.Trim();
        formModel.LastName = formModel.LastName.Trim();
        formModel.Email = string.IsNullOrWhiteSpace(formModel.Email)
            ? null
            : formModel.Email.Trim();

        if (editingEmployeeId is null)
        {
            await EmployeeService.CreateAsync(formModel);
            SetMessage(true, "Pracownik został dodany.");
        }
        else
        {
            formModel.Id = editingEmployeeId.Value;
            await EmployeeService.UpdateAsync(formModel);
            SetMessage(true, "Pracownik został zaktualizowany.");
        }

        ResetForm();
        await LoadAsync();
    }

    private void Edit(Employee employee)
    {
        editingEmployeeId = employee.Id;

        formModel = new Employee
        {
            Id = employee.Id,
            FirstName = employee.FirstName,
            LastName = employee.LastName,
            Email = employee.Email,
            IsCoordinator = employee.IsCoordinator,
            IsActive = employee.IsActive
        };

        ClearMessage();
    }

    private void CancelEdit()
    {
        ResetForm();
        ClearMessage();
    }

    private async Task SetCoordinatorAsync(int employeeId)
    {
        ClearMessage();

        await EmployeeService.SetCoordinatorAsync(employeeId);

        SetMessage(true, "Koordynator urlopów został ustawiony.");

        await LoadAsync();
    }

    private void ResetForm()
    {
        editingEmployeeId = null;

        formModel = new Employee
        {
            IsActive = true
        };
    }

    private void SetMessage(bool isSuccess, string text)
    {
        success = isSuccess;
        message = text;
    }

    private void ClearMessage()
    {
        message = null;
    }
}