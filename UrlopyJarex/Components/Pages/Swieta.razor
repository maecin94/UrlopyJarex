@page "/swieta"
@rendermode InteractiveServer

@using UrlopyJarex.Models
@using UrlopyJarex.Services

@inject HolidayService HolidayService

<PageTitle>Święta</PageTitle>

<h1>Święta państwowe</h1>

<p class="text-muted">
    Lista świąt używana do liczenia dni urlopu. Święta stałe obowiązują automatycznie w każdym roku,
    a święta ruchome należy dodać ręcznie jako konkretne daty.
</p>

@if (!string.IsNullOrWhiteSpace(message))
{
    <div class="alert @(success ? "alert-success" : "alert-danger")">
        @message
    </div>
}

<div class="card mb-4">
    <div class="card-header">
        Święta stałe
    </div>

    <div class="card-body">
        @if (!fixedHolidayDefinitions.Any())
        {
            <div class="alert alert-info">
                Brak zdefiniowanych świąt stałych.
            </div>
        }
        else
        {
            <table class="table table-striped table-hover align-middle">
                <thead>
                    <tr>
                        <th>Data</th>
                        <th>Nazwa</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var holiday in fixedHolidayDefinitions)
                    {
                        <tr>
                            <td>@holiday.DateText</td>
                            <td>
                                <strong>@holiday.Name</strong>
                            </td>
                            <td>
                                @if (holiday.IsActive)
                                {
                                    <span class="badge bg-success">Aktywne</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Nieaktywne</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        <p class="text-muted mt-3">
            Święta stałe są liczone automatycznie dla każdego roku. Święta ruchome, np.
            Poniedziałek Wielkanocny i Boże Ciało, dodawaj ręcznie w sekcji poniżej.
        </p>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">
        Dodaj / edytuj święto ruchome lub dodatkowe
    </div>

    <div class="card-body">
        <EditForm Model="formModel" OnValidSubmit="SaveAsync">
            <DataAnnotationsValidator />

            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Data</label>
                    <InputDate class="form-control" @bind-Value="formModel.HolidayDate" />
                </div>

                <div class="col-md-5">
                    <label class="form-label">Nazwa</label>
                    <InputText class="form-control" @bind-Value="formModel.Name" />
                </div>

                <div class="col-md-2 d-flex align-items-end">
                    <div class="form-check">
                        <InputCheckbox class="form-check-input" @bind-Value="formModel.IsActive" />
                        <label class="form-check-label">Aktywne</label>
                    </div>
                </div>

                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-primary w-100" type="submit">
                        Zapisz
                    </button>
                </div>
            </div>

            @if (editingHolidayId is not null)
            {
                <div class="mt-3">
                    <button class="btn btn-secondary" type="button" @onclick="CancelEdit">
                        Anuluj edycję
                    </button>
                </div>
            }
        </EditForm>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">
        Święta ruchome / dodatkowe dla roku
    </div>

    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-2">
                <label class="form-label">Rok</label>
                <InputNumber class="form-control" @bind-Value="selectedYear" />
            </div>

            <div class="col-md-2 d-flex align-items-end">
                <button class="btn btn-outline-primary w-100" @onclick="LoadAsync">
                    Pokaż
                </button>
            </div>
        </div>
    </div>
</div>

@if (holidays is null)
{
    <p>Ładowanie świąt...</p>
}
else if (!holidays.Any())
{
    <div class="alert alert-info">
        Brak ręcznie dodanych świąt dla roku @selectedYear.
    </div>
}
else
{
    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>Data</th>
                <th>Nazwa</th>
                <th>Status</th>
                <th style="width: 120px;">Akcje</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var holiday in holidays)
            {
                <tr>
                    <td>@holiday.HolidayDate.ToString("yyyy-MM-dd")</td>
                    <td>
                        <strong>@holiday.Name</strong>
                    </td>
                    <td>
                        @if (holiday.IsActive)
                        {
                            <span class="badge bg-success">Aktywne</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Nieaktywne</span>
                        }
                    </td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary" @onclick="() => Edit(holiday)">
                            Edytuj
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<HolidayDefinition> fixedHolidayDefinitions = new();
    private List<Holiday>? holidays;

    private int selectedYear = DateTime.Today.Year;

    private Holiday formModel = new()
    {
        HolidayDate = DateTime.Today,
        IsActive = true
    };

    private int? editingHolidayId;

    private string? message;
    private bool success;

    protected override async Task OnInitializedAsync()
    {
        fixedHolidayDefinitions = (await HolidayService.GetDefinitionsAsync()).ToList();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        ClearMessage();

        if (selectedYear < 2000 || selectedYear > 2100)
        {
            SetMessage(false, "Podaj poprawny rok.");
            return;
        }

        holidays = (await HolidayService.GetByYearAsync(selectedYear)).ToList();
    }

    private async Task SaveAsync()
    {
        ClearMessage();

        if (string.IsNullOrWhiteSpace(formModel.Name))
        {
            SetMessage(false, "Nazwa święta jest wymagana.");
            return;
        }

        (bool Success, string Message) result;

        if (editingHolidayId is null)
        {
            result = await HolidayService.CreateAsync(
                formModel.HolidayDate,
                formModel.Name);
        }
        else
        {
            formModel.Id = editingHolidayId.Value;

            result = await HolidayService.UpdateAsync(formModel);
        }

        SetMessage(result.Success, result.Message);

        if (result.Success)
        {
            selectedYear = formModel.HolidayDate.Year;
            ResetForm();
            await LoadAsync();
        }
    }

    private void Edit(Holiday holiday)
    {
        editingHolidayId = holiday.Id;

        formModel = new Holiday
        {
            Id = holiday.Id,
            HolidayDate = holiday.HolidayDate,
            Name = holiday.Name,
            IsActive = holiday.IsActive,
            CreatedAt = holiday.CreatedAt
        };

        ClearMessage();
    }

    private void CancelEdit()
    {
        ResetForm();
        ClearMessage();
    }

    private void ResetForm()
    {
        editingHolidayId = null;

        formModel = new Holiday
        {
            HolidayDate = DateTime.Today,
            IsActive = true
        };
    }

    private void SetMessage(bool isSuccess, string text)
    {
        success = isSuccess;
        message = text;
    }

    private void ClearMessage()
    {
        message = null;
    }
}