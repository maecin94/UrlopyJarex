@page "/anulowanie-urlopu"
@rendermode InteractiveServer

@using UrlopyJarex.Models
@using UrlopyJarex.Services

@inject VacationRequestService VacationRequestService

<PageTitle>Anulowanie urlopu</PageTitle>

<h1>Anulowanie urlopu</h1>

<p class="text-muted">
    Ten widok pokazuje tylko zaakceptowane urlopy. Anulowanie urlopu oddaje dni do rocznego limitu pracownika.
</p>

@if (!string.IsNullOrWhiteSpace(message))
{
    <div class="alert @(success ? "alert-success" : "alert-danger")">
        @message
    </div>
}

@if (requests is null)
{
    <p>Ładowanie urlopów...</p>
}
else if (!requests.Any())
{
    <div class="alert alert-info">
        Brak zaakceptowanych urlopów do anulowania.
    </div>
}
else
{
    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>Pracownik</th>
                <th>Zastępca</th>
                <th>Termin</th>
                <th>Dni</th>
                <th>Typ</th>
                <th>Komentarz anulowania</th>
                <th style="width: 180px;">Akcje</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var request in requests)
            {
                <tr>
                    <td>
                        <strong>@request.EmployeeFullName</strong>
                    </td>

                    <td>
                        @request.SubstituteEmployeeFullName
                    </td>

                    <td>
                        @request.DateFrom.ToString("yyyy-MM-dd")
                        –
                        @request.DateTo.ToString("yyyy-MM-dd")
                    </td>

                    <td>
                        @request.DaysCount
                    </td>

                    <td>
                        @request.VacationType.ToPolishName()
                    </td>

                    <td>
                        <textarea class="form-control"
                                  rows="2"
                                  placeholder="Opcjonalny powód anulowania"
                                  @bind="comments[request.Id]"></textarea>
                    </td>

                    <td>
                        @if (requestIdPendingCancelConfirmation == request.Id)
                        {
                            <div class="confirm-box">
                                <div class="confirm-text">
                                    Potwierdzić anulowanie?
                                </div>

                                <button class="btn btn-sm btn-danger"
                                        @onclick="() => CancelAsync(request.Id)">
                                    Tak, anuluj
                                </button>

                                <button class="btn btn-sm btn-secondary ms-1"
                                        @onclick="CancelConfirmation">
                                    Nie
                                </button>
                            </div>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-outline-dark"
                                    @onclick="() => AskCancelConfirmation(request.Id)">
                                Anuluj urlop
                            </button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<VacationRequest>? requests;
    private Dictionary<int, string?> comments = new();
    private int? requestIdPendingCancelConfirmation;

    private string? message;
    private bool success;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        requests = (await VacationRequestService.GetApprovedAsync()).ToList();

        comments = requests.ToDictionary(
            x => x.Id,
            x => x.CoordinatorComment
        );
    }

    private void AskCancelConfirmation(int requestId)
    {
        ClearMessage();
        requestIdPendingCancelConfirmation = requestId;
    }

    private void CancelConfirmation()
    {
        requestIdPendingCancelConfirmation = null;
    }

    private async Task CancelAsync(int requestId)
    {
        ClearMessage();

        comments.TryGetValue(requestId, out var comment);

        var result = await VacationRequestService.CancelApprovedByCoordinatorAsync(
            requestId,
            comment);

        requestIdPendingCancelConfirmation = null;

        SetMessage(result.Success, result.Message);

        await LoadAsync();
    }

    private void SetMessage(bool isSuccess, string text)
    {
        success = isSuccess;
        message = text;
    }

    private void ClearMessage()
    {
        message = null;
    }
}